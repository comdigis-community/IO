ext","text":"X axis"}]},{"text":": points to the ","type":"text"},{"type":"strong","inlineContent":[{"text":"right","type":"text"}]},{"text":" of the listener.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Y axis"}]},{"type":"text","text":": points "},{"type":"strong","inlineContent":[{"type":"text","text":"upward"}]},{"type":"text","text":" from the listener."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Z axis"}],"type":"strong"},{"text":": points ","type":"text"},{"inlineContent":[{"type":"text","text":"behind"}],"type":"strong"},{"text":" the listener.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The perceptual "},{"inlineContent":[{"text":"forward","type":"text"}],"type":"strong"},{"type":"text","text":" direction is defined as "},{"type":"strong","inlineContent":[{"text":"−Z","type":"text"}]},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"This means that:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Positions with ","type":"text"},{"inlineContent":[{"text":"negative Z","type":"text"}],"type":"strong"},{"text":" are interpreted as being ","type":"text"},{"inlineContent":[{"type":"text","text":"in front of the listener"}],"type":"strong"},{"text":".","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Positions with ","type":"text"},{"type":"strong","inlineContent":[{"text":"positive Z","type":"text"}]},{"text":" are interpreted as being ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"behind the listener"}]},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"The listener orientation is conceptually defined by the vectors ","type":"text"},{"code":"forward","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"up","type":"codeVoice"},{"text":",","type":"text"},{"type":"text","text":" "},{"type":"text","text":"forming an orthonormal basis consistent with a right-handed system. If non-orthogonal"},{"type":"text","text":" "},{"type":"text","text":"or non-normalized vectors are provided, the engine assumes an equivalent orthonormal"},{"type":"text","text":" "},{"type":"text","text":"basis derived from them."}],"type":"paragraph"},{"text":"Usage","anchor":"Usage","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"This class centralizes spatial state such as "},{"type":"emphasis","inlineContent":[{"type":"text","text":"doppler factor"}]},{"type":"text","text":" and speed of sound,"},{"type":"text","text":" "},{"type":"text","text":"allowing synchronization with internal presets. Values must be updated via"},{"type":"text","text":" "},{"type":"codeVoice","code":"synchronize()"},{"type":"text","text":" to remain consistent by the engine."}],"type":"paragraph"},{"syntax":"swift","code":["let listener = Listener()","listener.position = .init(0, 0, 1) \/\/ Positioned behind the listener (positive Z)"],"type":"codeListing"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use as reference for binaural, ensuring synchronization before processing.","type":"text"}]}],"name":"Note","style":"note","type":"aside"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Specifies the "},{"type":"emphasis","inlineContent":[{"text":"spatial listener","type":"text"}]},{"type":"text","text":" used for 3D audio."}],"variants":[{"paths":["\/documentation\/io\/listener"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/io.IO\/documentation\/IO"]]},"identifier":{"url":"doc:\/\/io.IO\/documentation\/IO\/Listener","interfaceLanguage":"swift"},"topicSections":[{"title":"Operators","identifiers":["doc:\/\/io.IO\/documentation\/IO\/Listener\/==(_:_:)"],"generated":true,"anchor":"Operators"},{"title":"Instance Properties","identifiers":["doc:\/\/io.IO\/documentation\/IO\/Lis