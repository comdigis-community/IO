tly."}]}],"type":"aside","style":"note","name":"Note"},{"type":"paragraph","inlineContent":[{"text":"This wrapper is suitable for real-time buffers, analysis results, or DSP state","type":"text"},{"text":" ","type":"text"},{"text":"where a single render-thread producer publishes updates and observers consume","type":"text"},{"text":" ","type":"text"},{"text":"stable snapshots without interfering with real-time execution.","type":"text"}]}],"kind":"content"}],"references":{"doc://io.IO/documentation/IO/Concurrent":{"abstract":[{"type":"text","text":"Specifies a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"double-buffer"}]},{"type":"text","text":" wrapper for "},{"type":"strong","inlineContent":[{"text":"render-writer\/control-reader","type":"text"}]},{"type":"text","text":"."}],"type":"topic","url":"\/documentation\/io\/concurrent","kind":"symbol","role":"symbol","title":"Concurrent","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"Concurrent"}],"navigatorTitle":[{"kind":"identifier","text":"Concurrent"}],"identifier":"doc:\/\/io.IO\/documentation\/IO\/Concurrent"},"doc://io.IO/documentation/IO/Concurrent/commit()":{"type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"commit","kind":"identifier"},{"text":"()","kind":"text"}],"title":"commit()","kind":"symbol","abstract":[{"type":"text","text":"Publishes the staged value for control-thread observation."}],"identifier":"doc:\/\/io.IO\/documentation\/IO\/Concurrent\/commit()","url":"\/documentation\/io\/concurrent\/commit()"},"doc://io.IO/documentation/IO/Concurrent/init(wrappedValue:)":{"identifier":"doc:\/\/io.IO\/documentation\/IO\/Concurrent\/init(wrappedValue:)","type":"topic","title":"init(wrappedValue:)","kind":"symbol","abstract":[{"text":"Creates the wrapper with an initial value.","type":"text"}],"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"e